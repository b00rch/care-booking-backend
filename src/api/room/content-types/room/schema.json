{
  "kind": "collectionType",
  "collectionName": "rooms",
  "info": {
    "singularName": "room",
    "pluralName": "rooms",
    "displayName": "Room"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "rooms"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 30,
      "required": true
    },
    "pricePerDay": {
      "type": "integer",
      "required": true
    },
    "priceWelfare": {
      "type": "integer"
    },
    "beds": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::bed.bed",
      "mappedBy": "room"
    }
  }
}
